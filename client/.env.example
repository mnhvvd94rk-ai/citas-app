# URL base del backend (server Express desplegado).
# En desarrollo suele ser http://localhost:3001
# En producción, la URL pública del server (Railway/Render), p.ej.:
#   VITE_API_URL="https://citas-server.up.railway.app"
# Úsala en el código del cliente con: import.meta.env.VITE_API_URL
VITE_API_URL="http://localhost:3001"

# Clave pública VAPID para Web Push (debe coincidir con VAPID_PUBLIC_KEY del server).
VITE_VAPID_PUBLIC_KEY=""
