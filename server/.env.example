# Puerto del servidor Express
PORT=3001

# Base de datos.
# En PRODUCCIÓN debe ser la cadena de "Connection Pooling" de Supabase
# (host con ...pooler.supabase.com, normalmente puerto 6543, pgbouncer):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"
# En desarrollo local puedes seguir usando SQLite con: "file:./dev.db"
# (recuerda que el provider del schema.prisma es ahora "postgresql").
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Auth (JWT)
JWT_SECRET="cambiar_en_produccion"
JWT_EXPIRES_IN="7d"

# SMTP (email). Si se dejan vacías, en desarrollo se usa una cuenta de prueba
# Ethereal generada automáticamente (nodemailer.createTestAccount()).
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Web Push (VAPID). Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu-correo@ejemplo.com"

# TWILIO WHATSAPP (opcional, para WhatsApp real)
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# SendGrid — formulario de contacto público (POST /contacto)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@kohtun.app"
CONTACT_EMAIL_TO="tu-email-personal@ejemplo.com"
