// Prisma schema — Citas App
// Basado en CONTEXT.md secciones 4 (modelo de datos) y 5 (reglas de negocio).
// Docs: https://pris.ly/d/prisma-schema
//
// ─────────────────────────────────────────────────────────────────────────
// DECISIONES DE DISEÑO (documentadas según pedido):
//
// 1. PROVIDER = postgresql (producción, p.ej. Supabase). El proyecto se
//    desarrolló inicialmente sobre SQLite, lo que dejó dos decisiones que se
//    MANTIENEN tal cual para no romper la lógica ya construida:
//      a) Los "enum" del CONTEXT.md se modelan como `String` con @default y
//         la lista de valores válidos documentada junto al campo; la
//         validación se hace en la capa de servicios. (Ahora que el motor es
//         Postgres, podrían convertirse a enums nativos en una migración
//         futura, pero NO se hace todavía.)
//      b) `fecha` es `DateTime` (no hay tipo `Date` puro en el modelado
//         actual). Postgres lo soporta sin cambios; opcionalmente migrable a
//         @db.Date más adelante.
//
// 2. IDs = Int autoincrement. Criterio: simplicidad en desarrollo. Se puede
//    cambiar a uuid (String @default(uuid())) sin afectar la lógica.
//
// 3. horaInicio / horaFin = String "HH:mm". Criterio: el día ya lo aporta
//    `fecha`; guardar la hora como "HH:mm" mantiene la aritmética de slots
//    (slotEngine, bloques de 45 min) simple y libre de zonas horarias.
//
// 4. Cita NO tiene FK a Disponibilidad. Criterio: los slots de 45 min son
//    derivados/calculados desde los rangos de Disponibilidad por el
//    slotEngine, no filas persistidas; además una Cita puede abarcar 2 slots
//    consecutivos. Ligarla a una sola fila de Disponibilidad sería ambiguo.
//    La Cita guarda fecha/horaInicio/horaFin directamente y la validación
//    contra la disponibilidad se hace en servicios. Por eso Disponibilidad
//    tampoco expone una relación a Cita.
//
// 5. Notificacion.destinatarioId = Int SIN FK. Criterio: el destinatario
//    puede ser Usuario(paciente) o Medico; una FK estricta no puede apuntar
//    a dos tablas. `tipoDestinatario` (PACIENTE | MEDICO) desambigua a qué
//    tabla pertenece el id. La integridad se garantiza en la capa de app.
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Paciente. estado: NUEVO | CONTINUIDAD (ver CONTEXT.md §5.4).
model Usuario {
  id                 Int            @id @default(autoincrement())
  nombre             String
  apellido           String
  documentoIdentidad String         @unique
  fotoIdentidadUrl   String?
  firmaUrl           String?
  telefono           String
  correo             String         @unique
  // Nullable: los clientes importados nacen sin contraseña; la crean ellos al
  // activar su cuenta (ver `cuentaActivada`).
  passwordHash       String?
  estado             String         @default("NUEVO") // NUEVO | CONTINUIDAD
  fechaRegistro      DateTime       @default(now())
  idiomaPreferido    String         @default("ES") // ES | EN | FR (para notificaciones)
  // Los clientes creados por registro propio nacen activados (true). Los
  // importados por el profesional nacen en false: no pueden iniciar sesión
  // hasta que activan la cuenta y definen su propia contraseña.
  cuentaActivada     Boolean        @default(true)

  // Gestión del cliente por el profesional (no proviene del registro):
  edadManual              Int?      // edad introducida a mano (no hay fecha de nacimiento)
  estadoTratamiento       String    @default("ACTIVO") // ACTIVO | COMPLETADO | EN_PAUSA
  tratamientoFinalizadoEn DateTime? // fecha en que se marcó COMPLETADO

  // Profesional al que pertenece este cliente. Cada profesional tiene su propio
  // espacio aislado con sus propios clientes: el cliente queda vinculado al
  // registrarse desde el enlace público del profesional (/reservar/:slug) o al
  // ser importado por él. Nullable por compatibilidad con filas antiguas; los
  // registros nuevos siempre lo llevan (no se permiten clientes sin profesional).
  profesional        Medico?        @relation(fields: [profesionalId], references: [id])
  profesionalId      Int?

  citas              Cita[]
  notas              NotaPaciente[]
  pushSubscriptions  PushSubscription[]
  dispositivos       DispositivoCliente[]

  @@index([profesionalId])
}

/// Gestor / médico.
model Medico {
  id               Int              @id @default(autoincrement())
  nombre           String
  especialidad     String
  telefono         String?
  correo           String           @unique
  passwordHash     String

  // Identificador público para su enlace de registro de clientes
  // (https://kohtun.com/reservar/<slug>). Se genera automáticamente a partir
  // del nombre al registrarse, con sufijo numérico si ya existe. Editable una
  // sola vez desde el panel; `slugEditado` marca que esa edición ya se usó.
  // Nullable solo por compatibilidad con filas previas a este campo.
  slug             String?          @unique
  slugEditado      Boolean          @default(false)

  // Idioma preferido para sus notificaciones (recordatorios al profesional).
  idiomaPreferido  String           @default("ES") // ES | EN | FR

  // Foto de perfil (opcional). Data URL / URL de imagen. Si es null, el frontend
  // usa el avatar genérico (inicial del nombre) como hasta ahora.
  fotoPerfilUrl    String?

  // Configuración de penalización por cancelación tardía (por defecto):
  costoCancelacion           Float @default(0)
  diasAnticipacionRequierida Int   @default(7)

  disponibilidades Disponibilidad[]
  citas            Cita[]
  notas            NotaPaciente[]
  clientes         Usuario[]
  pushSubscriptions PushSubscription[]
  dispositivos     DispositivoCliente[]
}

/// Token de dispositivo (refresh token opaco) para el login semi-automático de
/// un cliente desde el enlace de SU profesional (/reservar/:slug). Guarda solo el
/// HASH del token (nunca el valor en claro), asociado a la pareja
/// (clienteId, profesionalId). Se canjea por un JWT de sesión sin pedir
/// credenciales; se revoca al pulsar "No soy yo".
model DispositivoCliente {
  id            Int      @id @default(autoincrement())
  tokenHash     String   @unique
  cliente       Usuario  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId     Int
  profesional   Medico   @relation(fields: [profesionalId], references: [id], onDelete: Cascade)
  profesionalId Int
  expiraEn      DateTime
  createdAt     DateTime @default(now())
  ultimoUsoEn   DateTime @default(now())

  @@index([clienteId])
  @@index([profesionalId])
}

/// Suscripción Web Push de un dispositivo/navegador. Un mismo dispositivo puede
/// pertenecer a un cliente (Usuario) o a un profesional (Medico) según quién
/// activó las notificaciones desde su panel; por eso ambas relaciones son
/// opcionales (una suscripción concreta lleva una u otra). `keys` guarda el par
/// { p256dh, auth } que devuelve el navegador. `endpoint` identifica de forma
/// única a la suscripción.
model PushSubscription {
  id            Int      @id @default(autoincrement())
  endpoint      String   @unique
  keys          Json
  cliente       Usuario? @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId     Int?
  profesional   Medico?  @relation(fields: [profesionalId], references: [id], onDelete: Cascade)
  profesionalId Int?
  createdAt     DateTime @default(now())

  @@index([clienteId])
  @@index([profesionalId])
}

/// Rango de disponibilidad de un médico en un día. El slotEngine lo trocea
/// en bloques de 45 min consecutivos sin huecos (CONTEXT.md §5.1).
model Disponibilidad {
  id         Int      @id @default(autoincrement())
  medico     Medico   @relation(fields: [medicoId], references: [id])
  medicoId   Int
  fecha      DateTime // se usa solo la parte de fecha (ver decisión §1.b)
  horaInicio String   // "HH:mm"
  horaFin    String   // "HH:mm"
  // Duración del bloque en minutos con que el slotEngine trocea esta franja.
  // Default 45 para compatibilidad con las franjas creadas antes de este campo.
  duracionMinutos Int  @default(45)

  @@index([medicoId, fecha])
}

/// Cita reservada. estado: PENDIENTE | CONFIRMADA | ANULADA | COMPLETADA.
model Cita {
  id             Int      @id @default(autoincrement())
  paciente       Usuario  @relation(fields: [pacienteId], references: [id])
  pacienteId     Int
  medico         Medico   @relation(fields: [medicoId], references: [id])
  medicoId       Int
  fecha          DateTime // se usa solo la parte de fecha (ver decisión §1.b)
  horaInicio     String   // "HH:mm"
  horaFin        String   // "HH:mm"
  numeroSlots    Int      @default(1) // 1 o 2 (CONTEXT.md §5.2 / §5.3)
  estado         String   @default("PENDIENTE") // PENDIENTE | CONFIRMADA | ANULADA | COMPLETADA
  motivoConsulta String?  // solo si el paciente es NUEVO
  notaAnulacion  String?

  // Penalización por cancelación (copiada del médico al reservar). El campo
  // `diasAnticipacionRequierida` ya viene doblado si la cita es doble.
  costoCancelacion           Float   @default(0)
  diasAnticipacionRequierida Int     @default(7)
  esDoble                    Boolean @default(false)

  // Modalidad de la cita. PRESENCIAL | VIDEOCONFERENCIA. Si es videoconferencia
  // se genera un enlace único de Jitsi Meet (gratis, sin API key).
  tipoCita                String  @default("PRESENCIAL")
  enlaceVideoconferencia  String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([medicoId, fecha])
  @@index([pacienteId])
}

/// Nota libre del médico sobre un paciente. Historial abierto, no atado a una
/// cita concreta (CONTEXT.md §5.7). `texto` se almacena como TEXT en SQLite.
model NotaPaciente {
  id         Int      @id @default(autoincrement())
  paciente   Usuario  @relation(fields: [pacienteId], references: [id])
  pacienteId Int
  medico     Medico   @relation(fields: [medicoId], references: [id])
  medicoId   Int
  texto      String
  fecha      DateTime @default(now())
  // Opcional: si la nota está vinculada a una cita concreta. `null` = nota
  // general del cliente. Ref suelta (sin FK), como Notificacion.destinatarioId.
  citaId     Int?

  @@index([pacienteId])
  @@index([citaId])
}

/// Registro de notificación enviada/encolada. destinatarioId sin FK (ver §5).
model Notificacion {
  id               Int       @id @default(autoincrement())
  destinatarioId   Int       // sin FK: id de Usuario o Medico según tipoDestinatario
  tipoDestinatario String    // PACIENTE | MEDICO
  tipo             String    // ANULACION | RESUMEN_DIARIO
  canal            String    // EMAIL | SMS | PUSH
  estadoEnvio      String    @default("PENDIENTE") // PENDIENTE | ENVIADO | FALLIDO
  fechaEnvio       DateTime?
  createdAt        DateTime  @default(now())

  @@index([destinatarioId, tipoDestinatario])
}

/// Auditoría de recordatorios automáticos ya enviados, para no reenviar.
/// `tipo`: 48h | 24h | 3h. Único por (cita, tipo).
model NotificacionEnviada {
  id           Int      @id @default(autoincrement())
  citaId       Int
  tipo         String   // 48h | 24h | 3h
  fechaEnviada DateTime @default(now())

  @@unique([citaId, tipo])
}
